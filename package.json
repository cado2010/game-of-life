{
  "name": "game-of-life",
  "version": "1.0.0",
  "description": "Conway's Game of Life — infinite zoomable grid with pattern management",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "concurrently -n vite,server -c cyan,green \"vite\" \"tsx watch server/index.ts\"",
    "build": "tsc -b && vite build",
    "start": "tsx server/index.ts",
    "build:electron-main": "esbuild electron/main.ts --bundle --platform=node --format=cjs --outfile=dist-electron/main.cjs --external:electron",
    "electron:dev": "npm run build:electron-main && concurrently -n vite,server,electron -c cyan,green,magenta \"vite\" \"tsx watch server/index.ts\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && npm run build:electron-main && electron-builder",
    "lint": "eslint src/ server/"
  },
  "author": "Game of Life",
  "build": {
    "appId": "com.gameoflife.app",
    "productName": "Game of Life",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "patterns/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "dir",
      "signAndEditExecutable": false
    },
    "forceCodeSigning": false
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.27.4",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.1",
    "wait-on": "^9.0.4"
  }
}
